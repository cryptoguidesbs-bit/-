// Prisma schema draft — Stage 1
// Convention: all DateTime values are stored in UTC (Prisma default).
// Client-side rendering converts to the user's local timezone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime (app): pooled connection. On serverless (Vercel) this MUST be the
  // pooled endpoint — e.g. Neon's "-pooler" host — so many short-lived
  // function invocations don't exhaust Postgres connections.
  url = env("DATABASE_URL")
  // Migrations (prisma migrate/db push): a direct, non-pooled connection.
  // Locally this equals DATABASE_URL; on Neon it's the non-pooler host.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum SubscriptionPlan {
  FREE
  STARTER
  TRADER
  PRO
  WHALE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  INCOMPLETE
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING
  INVESTMENT_DISCLAIMER
}

enum NewsRegion {
  US
  EUROPE
  ASIA
  GLOBAL
}

enum NewsCategory {
  MARKET
  REGULATION
  TECHNOLOGY
  DEFI
  MACRO
  GENERAL
}

// AI enrichment lifecycle: PENDING → PUBLISHED, or HELD when the output
// fails sanity checks after retries.
enum NewsAiStatus {
  PENDING
  PUBLISHED
  HELD
}

enum NewsSentiment {
  BULLISH
  NEUTRAL
  BEARISH
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  REVIEW
}

enum ContentType {
  ARTICLE
  REPORT
  BRIEF
}

enum ReportCadence {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum ReportCategory {
  ETF
  MACRO
  ONCHAIN
}

enum BriefTier {
  STANDARD
  DETAILED
}

enum BriefStatus {
  PUBLISHED
  HELD
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  // Clerk user ID — the source of truth for authentication.
  clerkId   String   @unique
  email     String   @unique
  name      String?
  image     String?
  role      UserRole @default(USER)
  locale    String   @default("ko")
  // Display-only preference. Persisted data stays in UTC.
  timezone  String   @default("Asia/Seoul")
  // ISO 3166-1 alpha-2, captured from the geo header at consent time.
  // Used for region policies that must be evaluated outside a request
  // context (e.g. referral reward accrual in webhooks).
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription  Subscription?
  portfolios    Portfolio[]
  watchlists    Watchlist[]
  articles      Article[]
  consentLogs   ConsentLog[]
  auditLogs     ContentAuditLog[]
  savedArticles SavedArticle[]
  savedReports  SavedReport[]
  notifications Notification[]
  alertRules    AlertRule[]
  alertChannels AlertChannelConfig[]
  alertDeliveries AlertDelivery[]
  referralCode    ReferralCode?
  referralsMade   Referral[]       @relation("referralsMade")
  referralReceived Referral?       @relation("referralReceived")
  referralRewards ReferralReward[]
  apiKeys     ApiKey[]
  apiWebhooks ApiWebhook[]
  securityEvents SecurityEvent[]
  accessLogs  AccessLog[]
}

// ---------------------------------------------------------------------------
// Access log (stage 21b) — lightweight "service was used" signal, throttled
// to one row per user/kind/hour. Determines annual-refund eligibility
// (unused within 14 days → full refund). NOT analytics; minimal by design.
// ---------------------------------------------------------------------------

model AccessLog {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  // UTC hour bucket, YYYY-MM-DDTHH — dedupes repeated views within the hour.
  hourBucket String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, hourBucket])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Security audit trail (stage 21) — sensitive actions (account erasure,
// data export, admin member/region changes, blocked requests). Append-only;
// userId is SetNull on user deletion so the audit outlives the account.
// ---------------------------------------------------------------------------

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  // Actor email captured inline so the record survives account deletion.
  actorEmail String?
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Admin operations (stage 19) — runtime region/feature switches and the
// ops-event stream produced by the automated monitor.
// ---------------------------------------------------------------------------

// Runtime override of the static featureRegionPolicy — lets an operator
// react to regulation changes without a deploy. enabled=false kills the
// feature everywhere; a non-empty whitelist replaces the config whitelist.
model FeatureSwitch {
  id           String   @id @default(cuid())
  feature      String   @unique
  enabled      Boolean  @default(true)
  whitelist    String[]
  allowUnknown Boolean?
  updatedBy    String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// Anomalies and operational signals detected by the automated monitor.
// An unresolved event of the same kind suppresses duplicates.
model OpsEvent {
  id         String    @id @default(cuid())
  kind       String
  severity   String
  message    String
  data       Json?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([kind, resolvedAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Crypto Map (결제 지도) — BTCMap sync cache + our managed country regulation.
// Informational only; not transaction brokering. Access requires login
// (all plans free — no FEATURE_MIN_PLAN entry).
// ---------------------------------------------------------------------------

enum MapPlaceSource {
  BTCMAP
  MANUAL
}

enum RegulationStatus {
  FRIENDLY
  REGULATED
  RESTRICTED
  HOSTILE
  UNCLEAR
}

// Server-synced snapshot of BTCMap merchants/ATMs — the origin for client
// viewport (bbox) queries. Refreshed by /api/map/sync (cron/admin).
model MapPlace {
  id          String         @id @default(cuid())
  source      MapPlaceSource @default(BTCMAP)
  externalId  String
  name        String?
  lat         Float
  lng         Float
  category    String?
  coins       String[]
  address     String?
  countryCode String?
  verifiedAt  DateTime?
  raw         Json?
  syncedAt    DateTime       @default(now())

  @@unique([source, externalId])
  @@index([lat, lng])
  @@index([category])
  @@index([countryCode])
}

// Our managed per-country regulation status (major countries). Seeded from
// src/config/crypto-regulation.ts; editable via admin later. Informational,
// not legal advice.
model CountryRegulation {
  countryCode String           @id
  status      RegulationStatus
  summaryKo   String
  summaryEn   String
  sourceNote  String?
  updatedBy   String?
  updatedAt   DateTime         @updatedAt
}

// ---------------------------------------------------------------------------
// API Center (stage 18, Whale) — keys, per-day usage aggregation,
// outbound webhooks. The full key is shown once at creation; only a salted
// hash and a display prefix are stored.
// ---------------------------------------------------------------------------

model ApiKey {
  id      String  @id @default(cuid())
  userId  String
  name    String
  // Display prefix, e.g. "cg_live_AB12…" — never the full key.
  prefix  String
  keyHash String  @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage ApiUsage[]

  @@index([userId])
}

model ApiUsage {
  id       String @id @default(cuid())
  apiKeyId String
  endpoint String
  // UTC day bucket, YYYY-MM-DD.
  day   String
  count Int    @default(0)

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, endpoint, day])
  @@index([apiKeyId, day])
}

model ApiWebhook {
  id     String   @id @default(cuid())
  userId String
  url    String
  // Subscribed events, e.g. ["brief.published", "report.published"].
  events String[]
  // HMAC-SHA256 signing secret (kept server-side to sign each delivery).
  secret String
  active Boolean @default(true)
  lastDeliveryAt DateTime?
  lastStatus     Int?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Referral program (stage 17) — codes, attributions, reward ledger.
// Monetary rewards are region-gated ('referral.rewards' policy); rejected
// attributions are kept as REJECTED rows for abuse auditing.
// ---------------------------------------------------------------------------

enum ReferralStatus {
  PENDING
  QUALIFIED
  REJECTED
}

enum RewardStatus {
  PENDING
  APPROVED
  PAID
  VOID
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  referredUserId String         @unique
  code           String
  status         ReferralStatus @default(PENDING)
  // Hashed signup IP (sha256 + salt) — for duplicate/self-signup detection.
  ipHash      String?
  // Why a REJECTED attribution was refused (audit trail).
  reason      String?
  qualifiedAt DateTime?
  createdAt   DateTime  @default(now())

  referrer User             @relation("referralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User             @relation("referralReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  rewards  ReferralReward[]

  @@index([referrerId, status])
  @@index([ipHash])
}

model ReferralReward {
  id         String       @id @default(cuid())
  // The referrer receiving the reward.
  userId     String
  referralId String
  amountUsd  Decimal      @db.Decimal(10, 2)
  status     RewardStatus @default(PENDING)
  note       String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id                 String                @id @default(cuid())
  userId             String                @unique
  plan               SubscriptionPlan      @default(FREE)
  status             SubscriptionStatus    @default(ACTIVE)
  interval           SubscriptionInterval?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean               @default(false)
  // Scheduled downgrade — applied at currentPeriodEnd (no immediate refund).
  // Cleared once the provider transitions to the lower plan.
  pendingPlan     SubscriptionPlan?
  pendingInterval SubscriptionInterval?
  // Set when an annual full refund was issued (14-day unused window).
  refundedAt      DateTime?
  // IDs from the external payment provider (e.g. Stripe).
  externalId         String?               @unique
  externalCustomerId String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  currency    String   @default("KRW")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PortfolioItem[]

  @@index([userId])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  portfolioId String
  symbol      String
  market      String? // e.g. KRX, NASDAQ, NYSE
  quantity    Decimal  @default(0)
  avgCost     Decimal  @default(0)
  currency    String   @default("KRW")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  symbol      String
  market      String?
  note        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

model Article {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("ko")
  title       String
  summary     String?
  content     String
  status      ContentStatus @default(DRAFT)
  tags        String[]      @default([])
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author    User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  auditLogs ContentAuditLog[]

  @@unique([slug, locale])
  @@index([status, publishedAt])
}

model Report {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("ko")
  title       String
  summary     String?
  content     String
  status      ContentStatus @default(DRAFT)
  isPremium   Boolean       @default(true)
  fileUrl     String?
  publishedAt DateTime?
  // Premium research metadata (stage 14)
  cadence    ReportCadence?
  category   ReportCategory?
  periodKey  String?
  aiModel    String?
  reviewNote String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  auditLogs ContentAuditLog[]
  savedBy   SavedReport[]

  @@unique([slug, locale])
  @@index([status, publishedAt])
}

// ---------------------------------------------------------------------------
// News system (stage 8) — ingested articles + AI enrichment
// ---------------------------------------------------------------------------

model NewsItem {
  id          String       @id @default(cuid())
  // Dedupe key: sha256 of the normalized article URL.
  urlHash     String       @unique
  title       String
  url         String
  source      String
  region      NewsRegion
  category    NewsCategory @default(GENERAL)
  publishedAt DateTime
  ingestedAt  DateTime     @default(now())

  // AI enrichment (news-tone analysis, not investment advice)
  aiStatus     NewsAiStatus   @default(PENDING)
  summaryKo    String?
  summaryEn    String?
  sentiment    NewsSentiment?
  confidence   Int?
  aiModel      String?
  aiAttempts   Int            @default(0)
  aiHoldReason String?

  savedBy SavedArticle[]

  @@index([publishedAt])
  @@index([aiStatus, publishedAt])
  @@index([category, publishedAt])
  @@index([region, publishedAt])
}

// ---------------------------------------------------------------------------
// Member dashboard (stage 10) — saved content + notifications
// ---------------------------------------------------------------------------

model SavedArticle {
  id         String   @id @default(cuid())
  userId     String
  newsItemId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)

  @@unique([userId, newsItemId])
  @@index([userId, createdAt])
}

model SavedReport {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId, createdAt])
}

enum NotificationType {
  SYSTEM
  BRIEF
  NEWS
  BILLING
  ALERT
}

enum AlertType {
  PRICE
  WHALE
  PATTERN
  MACRO
}

enum AlertChannel {
  INAPP
  TELEGRAM
  EMAIL
  PUSH
}

enum DeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ---------------------------------------------------------------------------
// Alert system (stage 16) — rules, channel configs, delivery log
// ---------------------------------------------------------------------------

model AlertRule {
  id      String       @id @default(cuid())
  userId  String
  type    AlertType
  channel AlertChannel
  // Per-type parameters:
  //   PRICE   { symbol, direction: above|below, threshold }
  //   WHALE   { minUsd }
  //   PATTERN { symbol, interval, minConfidence }
  //   MACRO   { low, high }  (Fear & Greed extremes)
  params      Json
  active      Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries AlertDelivery[]

  @@index([userId])
  @@index([type, active])
}

model AlertChannelConfig {
  id      String       @id @default(cuid())
  userId  String
  channel AlertChannel
  // TELEGRAM { chatId } · PUSH { subscription } · EMAIL { address }
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
}

model AlertDelivery {
  id      String         @id @default(cuid())
  ruleId  String?
  userId  String
  type    AlertType
  channel AlertChannel
  title   String
  body    String
  status  DeliveryStatus
  // 'live' (real provider) or 'dev' (no credentials — logged only)
  transport String?
  error     String?
  createdAt DateTime @default(now())

  rule AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ruleId])
}

// ---------------------------------------------------------------------------
// AI Market Brief (stage 9) — non-personalized, tiered daily briefings
// ---------------------------------------------------------------------------

model MarketBrief {
  id String @id @default(cuid())
  // UTC date of the brief, YYYY-MM-DD.
  briefDate String
  tier      BriefTier
  status    BriefStatus
  // { btc, eth, altcoin, macro, today } — each { ko, en }.
  sections Json
  // Market data + headlines the generation was grounded in (traceability).
  inputsSnapshot Json?
  aiModel        String
  attempts       Int     @default(0)
  holdReason     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([briefDate, tier])
  @@index([status, briefDate])
}

// Daily LLM usage counter — cost / rate-limit management.
model AiUsage {
  id           String   @id @default(cuid())
  // UTC day, YYYY-MM-DD.
  day          String   @unique
  calls        Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Compliance / audit — append-only logs, never updated or deleted in app code
// ---------------------------------------------------------------------------

model ConsentLog {
  id        String      @id @default(cuid())
  userId    String
  type      ConsentType
  // Version of the document the user consented to (e.g. "2026-07-01").
  version   String
  granted   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model ContentAuditLog {
  id          String      @id @default(cuid())
  // Actor. Null when performed by system jobs.
  userId      String?
  action      AuditAction
  contentType ContentType
  contentId   String
  articleId   String?
  reportId    String?
  // Snapshot / diff of the change for traceability.
  diff        Json?
  reason      String?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  report  Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([contentType, contentId, createdAt])
  @@index([userId, createdAt])
}
