// Prisma schema draft — Stage 1
// Convention: all DateTime values are stored in UTC (Prisma default).
// Client-side rendering converts to the user's local timezone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum SubscriptionPlan {
  FREE
  STANDARD
  PROFESSIONAL
  INSTITUTIONAL
  LEGENDARY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  INCOMPLETE
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING
  INVESTMENT_DISCLAIMER
}

enum NewsRegion {
  US
  EUROPE
  ASIA
  GLOBAL
}

enum NewsCategory {
  MARKET
  REGULATION
  TECHNOLOGY
  DEFI
  MACRO
  GENERAL
}

// AI enrichment lifecycle: PENDING → PUBLISHED, or HELD when the output
// fails sanity checks after retries.
enum NewsAiStatus {
  PENDING
  PUBLISHED
  HELD
}

enum NewsSentiment {
  BULLISH
  NEUTRAL
  BEARISH
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  REVIEW
}

enum ContentType {
  ARTICLE
  REPORT
  BRIEF
}

enum BriefTier {
  STANDARD
  DETAILED
}

enum BriefStatus {
  PUBLISHED
  HELD
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  // Clerk user ID — the source of truth for authentication.
  clerkId   String   @unique
  email     String   @unique
  name      String?
  image     String?
  role      UserRole @default(USER)
  locale    String   @default("ko")
  // Display-only preference. Persisted data stays in UTC.
  timezone  String   @default("Asia/Seoul")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription  Subscription?
  portfolios    Portfolio[]
  watchlists    Watchlist[]
  articles      Article[]
  consentLogs   ConsentLog[]
  auditLogs     ContentAuditLog[]
  savedArticles SavedArticle[]
  savedReports  SavedReport[]
  notifications Notification[]
}

model Subscription {
  id                 String                @id @default(cuid())
  userId             String                @unique
  plan               SubscriptionPlan      @default(FREE)
  status             SubscriptionStatus    @default(ACTIVE)
  interval           SubscriptionInterval?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean               @default(false)
  // IDs from the external payment provider (e.g. Stripe).
  externalId         String?               @unique
  externalCustomerId String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  currency    String   @default("KRW")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PortfolioItem[]

  @@index([userId])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  portfolioId String
  symbol      String
  market      String? // e.g. KRX, NASDAQ, NYSE
  quantity    Decimal  @default(0)
  avgCost     Decimal  @default(0)
  currency    String   @default("KRW")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  symbol      String
  market      String?
  note        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

model Article {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("ko")
  title       String
  summary     String?
  content     String
  status      ContentStatus @default(DRAFT)
  tags        String[]      @default([])
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author    User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  auditLogs ContentAuditLog[]

  @@unique([slug, locale])
  @@index([status, publishedAt])
}

model Report {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("ko")
  title       String
  summary     String?
  content     String
  status      ContentStatus @default(DRAFT)
  isPremium   Boolean       @default(true)
  fileUrl     String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  auditLogs ContentAuditLog[]
  savedBy   SavedReport[]

  @@unique([slug, locale])
  @@index([status, publishedAt])
}

// ---------------------------------------------------------------------------
// News system (stage 8) — ingested articles + AI enrichment
// ---------------------------------------------------------------------------

model NewsItem {
  id          String       @id @default(cuid())
  // Dedupe key: sha256 of the normalized article URL.
  urlHash     String       @unique
  title       String
  url         String
  source      String
  region      NewsRegion
  category    NewsCategory @default(GENERAL)
  publishedAt DateTime
  ingestedAt  DateTime     @default(now())

  // AI enrichment (news-tone analysis, not investment advice)
  aiStatus     NewsAiStatus   @default(PENDING)
  summaryKo    String?
  summaryEn    String?
  sentiment    NewsSentiment?
  confidence   Int?
  aiModel      String?
  aiAttempts   Int            @default(0)
  aiHoldReason String?

  savedBy SavedArticle[]

  @@index([publishedAt])
  @@index([aiStatus, publishedAt])
  @@index([category, publishedAt])
  @@index([region, publishedAt])
}

// ---------------------------------------------------------------------------
// Member dashboard (stage 10) — saved content + notifications
// ---------------------------------------------------------------------------

model SavedArticle {
  id         String   @id @default(cuid())
  userId     String
  newsItemId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)

  @@unique([userId, newsItemId])
  @@index([userId, createdAt])
}

model SavedReport {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId, createdAt])
}

enum NotificationType {
  SYSTEM
  BRIEF
  NEWS
  BILLING
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ---------------------------------------------------------------------------
// AI Market Brief (stage 9) — non-personalized, tiered daily briefings
// ---------------------------------------------------------------------------

model MarketBrief {
  id String @id @default(cuid())
  // UTC date of the brief, YYYY-MM-DD.
  briefDate String
  tier      BriefTier
  status    BriefStatus
  // { btc, eth, altcoin, macro, today } — each { ko, en }.
  sections Json
  // Market data + headlines the generation was grounded in (traceability).
  inputsSnapshot Json?
  aiModel        String
  attempts       Int     @default(0)
  holdReason     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([briefDate, tier])
  @@index([status, briefDate])
}

// Daily LLM usage counter — cost / rate-limit management.
model AiUsage {
  id           String   @id @default(cuid())
  // UTC day, YYYY-MM-DD.
  day          String   @unique
  calls        Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Compliance / audit — append-only logs, never updated or deleted in app code
// ---------------------------------------------------------------------------

model ConsentLog {
  id        String      @id @default(cuid())
  userId    String
  type      ConsentType
  // Version of the document the user consented to (e.g. "2026-07-01").
  version   String
  granted   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model ContentAuditLog {
  id          String      @id @default(cuid())
  // Actor. Null when performed by system jobs.
  userId      String?
  action      AuditAction
  contentType ContentType
  contentId   String
  articleId   String?
  reportId    String?
  // Snapshot / diff of the change for traceability.
  diff        Json?
  reason      String?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  report  Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([contentType, contentId, createdAt])
  @@index([userId, createdAt])
}
