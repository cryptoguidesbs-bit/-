# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — all timestamps are stored in UTC
# Local dev: `npm run db:start` launches the embedded PostgreSQL.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insight?schema=public

# ---------------------------------------------------------------------------
# Clerk (authentication) — leave empty in development to use Clerk's keyless
# mode (a temporary dev instance; claim it from the terminal link).
# Production requires real keys from https://dashboard.clerk.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---------------------------------------------------------------------------
# Stripe (payments) — TEST keys from https://dashboard.stripe.com/test/apikeys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# From `stripe listen` or the dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=
# Which PaymentProvider implementation to use (default: stripe).
PAYMENT_PROVIDER=stripe

# Price IDs — generated by `npm run stripe:seed` (written to .env, not here).
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_INSTITUTIONAL_MONTHLY=
STRIPE_PRICE_INSTITUTIONAL_YEARLY=
STRIPE_PRICE_LEGENDARY_MONTHLY=
STRIPE_PRICE_LEGENDARY_YEARLY=

# ---------------------------------------------------------------------------
# Sentry — leave empty to disable error reporting locally
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Required only for source map upload in CI/production builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
