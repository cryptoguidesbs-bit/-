# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public origin of the deployed site (SEO, checkout redirects, API docs links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — all timestamps are stored in UTC
# Local dev: `npm run db:start` launches the embedded PostgreSQL.
# Production: a hosted Postgres URL. Prisma CLI reads this from .env.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insight?schema=public

# ---------------------------------------------------------------------------
# Clerk (authentication) — leave empty in development to use Clerk's keyless
# mode (a temporary dev instance; claim it from the terminal link).
# Production requires real keys from https://dashboard.clerk.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Svix signing secret for the Clerk webhook (/api/webhooks/clerk).
# REQUIRED in production — without it every Clerk webhook delivery is
# rejected (user.deleted/user.updated sync will not run).
CLERK_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Stripe (payments) — TEST keys from https://dashboard.stripe.com/test/apikeys
# Production: live keys + a real webhook endpoint for /api/billing/webhook.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# From `stripe listen` or the dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=
# Which PaymentProvider implementation to use (default: stripe).
PAYMENT_PROVIDER=stripe

# Price IDs — generated by `npm run stripe:seed` (written to .env, not here).
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_INSTITUTIONAL_MONTHLY=
STRIPE_PRICE_INSTITUTIONAL_YEARLY=
STRIPE_PRICE_LEGENDARY_MONTHLY=
STRIPE_PRICE_LEGENDARY_YEARLY=

# ---------------------------------------------------------------------------
# Internal pipelines — shared secret for cron triggers (x-cron-secret header):
# news ingest/summarize, daily brief, reports, alert engine, referral qualify,
# ops monitor, crypto-map sync. Admin sessions can trigger without it.
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# AI (news summaries / briefs / reports / portfolio commentary) — leave empty
# to use the built-in deterministic mock provider. Setting a key switches the
# whole pipeline to the real Claude API automatically.
# Get a key at https://platform.claude.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Model override (default: claude-opus-4-8)
AI_MODEL=
# Force a provider: "mock" (default when no key) or "anthropic"
AI_PROVIDER=
# Daily model-call budget (default 200) and inter-call spacing in ms
AI_DAILY_CALL_LIMIT=
AI_CALL_SPACING_MS=

# ---------------------------------------------------------------------------
# Notifications (stage 16 alerts + renewal reminders) — leave empty to record
# deliveries with the 'dev' transport (logged only, no external send).
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=
ALERT_EMAIL_FROM=
# Browser push (generate a pair: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@example.com

# ---------------------------------------------------------------------------
# Referral — salt for hashed signup IPs (falls back to CRON_SECRET)
# ---------------------------------------------------------------------------
REFERRAL_IP_SALT=

# ---------------------------------------------------------------------------
# Public API (/api/v1) — per-key requests/minute (default 60)
# ---------------------------------------------------------------------------
API_RATE_LIMIT_PER_MIN=

# ---------------------------------------------------------------------------
# Sentry — leave empty to disable error reporting locally.
# SENTRY_ORG/PROJECT/AUTH_TOKEN also power the admin-console error card.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
